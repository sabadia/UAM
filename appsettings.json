{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "Jwt": {
      "Issuer": "microservice",
      "Audience": "microservice-clients",
      "RequireHttpsMetadata": false
    }
  },
  "RemoteServices": {
    "TenantGrpcEndpoint": "https://localhost:7001",
    "IdentityGrpcEndpoint": "https://localhost:7002"
  },
  "AllowedHosts": "*"
}
