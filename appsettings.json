{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "Jwt": {
      "Issuer": "slogtry",
      "Audience": "slogtry-clients",
      "RequireHttpsMetadata": false
    }
  },
  "RemoteServices": {
    "Tenant": {
      "GrpcEndpoint": "https://localhost:7134"
    },
    "Identity": {
      "GrpcEndpoint": "https://localhost:7133"
    }
  },
  "AllowedHosts": "*"
}
